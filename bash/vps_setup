#!/usr/bin/env bash
set -euo pipefail

############################################
# FULL VPS SETUP: NGINX + POSTGRES + STORAGE
# + Remote Postgres access from Windows (IP-restricted)
############################################

###############
# CONFIG (EDIT)
###############

# Domains (must point to your VPS public IP for TLS)
BLOG_DOMAIN="blog.example.com"
OS_DOMAIN="os.example.com"
CDN_DOMAIN=""               # optional; leave empty to skip

LE_EMAIL="you@example.com"
ENABLE_TLS=0                # set to 1 after DNS works and port 80 reachable

# Blog hosting mode:
# 1 = reverse proxy to app listening on localhost (Node/Django/etc.)
# 0 = static files served from BLOG_STATIC_ROOT
BLOG_PROXY_ENABLED=1
BLOG_UPSTREAM_HOST="127.0.0.1"
BLOG_UPSTREAM_PORT="3000"
BLOG_MAX_UPLOAD="100m"

# Storage paths
BLOG_APP_ROOT="/var/www/blog"
BLOG_STATIC_ROOT="/var/www/blog/public"
BLOG_UPLOAD_DIR="/srv/blog/uploads"
OS_ISO_DIR="/srv/os/isos"
BACKUP_DIR="/srv/backups/postgres"

# Linux users
BLOG_USER="blogapp"
OS_USER="osapp"

# Postgres databases/users (2 separate DBs as a clean default)
PG_BLOG_DB="blogdb"
PG_BLOG_USER="bloguser"
PG_OS_DB="osdb"
PG_OS_USER="osuser"

# If left blank, strong random passwords are generated and saved to /root/.secrets/
PG_BLOG_PASS=""
PG_OS_PASS=""

# Enable remote Postgres access?
PG_ALLOW_REMOTE=1

# IMPORTANT: Restrict Postgres remote access to YOUR Windows public IP/CIDR.
# Example: WINDOWS_IP_CIDR="203.0.113.45/32"
WINDOWS_IP_CIDR="YOUR_PUBLIC_IP/32"

# Security toggles
ENABLE_UFW=1
ENABLE_FAIL2BAN=1
ENABLE_UNATTENDED_UPGRADES=1


###############
# Helpers
###############
log()  { echo -e "\n\033[1;32m==>\033[0m $*"; }
warn() { echo -e "\n\033[1;33m[WARN]\033[0m $*"; }

require_root() {
  [[ "${EUID}" -eq 0 ]] || { echo "Run as root: sudo $0"; exit 1; }
}

rand_pass() {
  openssl rand -base64 36 | tr -d '=+/' | cut -c1-32
}

ensure_user() {
  local u="$1"
  if id -u "$u" &>/dev/null; then
    log "User exists: $u"
  else
    log "Creating user: $u"
    useradd -m -s /bin/bash "$u"
  fi
}

postgres_conf_dir() {
  # Works on Ubuntu cluster layout (/etc/postgresql/<ver>/main)
  local line ver cluster
  line="$(pg_lsclusters --no-header 2>/dev/null | head -n1 || true)"
  [[ -n "$line" ]] || { echo ""; return 0; }
  read -r ver cluster _rest <<<"$line"
  echo "/etc/postgresql/${ver}/${cluster}"
}

###############
# Install
###############
install_packages() {
  log "Updating system + installing packages"
  export DEBIAN_FRONTEND=noninteractive
  apt-get update -y
  apt-get upgrade -y

  apt-get install -y \
    nginx \
    postgresql postgresql-contrib \
    ufw fail2ban \
    unattended-upgrades \
    certbot python3-certbot-nginx \
    ssl-cert \
    curl ca-certificates jq git unzip \
    logrotate
}

###############
# Firewall / Hardening
###############
configure_ufw() {
  [[ "$ENABLE_UFW" -eq 1 ]] || { warn "UFW disabled by config"; return 0; }

  log "Configuring UFW firewall"
  # Best practice: allow SSH before enabling firewall to avoid lockout. [4](https://www.digitalocean.com/community/tutorials/ufw-essentials-common-firewall-rules-and-commands)
  ufw allow OpenSSH || true

  if ufw app list 2>/dev/null | grep -q "Nginx Full"; then
    ufw allow "Nginx Full" || true
  else
    ufw allow 80/tcp || true
    ufw allow 443/tcp || true
  fi

  # Postgres remote access (restricted)
  if [[ "$PG_ALLOW_REMOTE" -eq 1 ]]; then
    if [[ "$WINDOWS_IP_CIDR" == "YOUR_PUBLIC_IP/32" || -z "$WINDOWS_IP_CIDR" ]]; then
      warn "WINDOWS_IP_CIDR is not set. NOT opening port 5432."
      warn "Set WINDOWS_IP_CIDR to your Windows public IP (e.g., 203.0.113.45/32)."
    else
      log "Allowing Postgres port 5432 ONLY from $WINDOWS_IP_CIDR"
      ufw allow from "$WINDOWS_IP_CIDR" to any port 5432 proto tcp
    fi
  fi

  ufw --force enable
  ufw status verbose || true
}

configure_fail2ban() {
  [[ "$ENABLE_FAIL2BAN" -eq 1 ]] || { warn "fail2ban disabled by config"; return 0; }

  log "Configuring fail2ban (sshd jail)"
  mkdir -p /etc/fail2ban/jail.d
  cat >/etc/fail2ban/jail.d/sshd.local <<'EOF'
[sshd]
enabled = true
maxretry = 5
findtime = 10m
bantime  = 1h
EOF
  systemctl enable --now fail2ban
}

configure_unattended() {
  [[ "$ENABLE_UNATTENDED_UPGRADES" -eq 1 ]] || { warn "unattended upgrades disabled by config"; return 0; }

  log "Enabling unattended security updates"
  # Typical enablement uses dpkg-reconfigure unattended-upgrades. [5](https://askubuntu.com/questions/9/how-do-i-enable-automatic-updates)[6](https://oneuptime.com/blog/post/2026-03-02-configure-unattended-upgrades-security-patches-ubuntu/view)
  dpkg-reconfigure -f noninteractive unattended-upgrades || true

  cat >/etc/apt/apt.conf.d/20auto-upgrades <<'EOF'
APT::Periodic::Update-Package-Lists "1";
APT::Periodic::Download-Upgradeable-Packages "1";
APT::Periodic::AutocleanInterval "7";
APT::Periodic::Unattended-Upgrade "1";
EOF

  systemctl enable --now unattended-upgrades || true
}

###############
# Directories
###############
create_dirs() {
  log "Creating directories"
  mkdir -p \
    "$BLOG_APP_ROOT" "$BLOG_STATIC_ROOT" \
    "$BLOG_UPLOAD_DIR" \
    "$OS_ISO_DIR" \
    "$BACKUP_DIR"

  chown -R "$BLOG_USER:$BLOG_USER" "$BLOG_APP_ROOT" "$BLOG_UPLOAD_DIR"
  chown -R "$OS_USER:$OS_USER" "$OS_ISO_DIR"
  chmod 0750 /srv || true
}

###############
# PostgreSQL
###############
configure_postgres() {
  log "Configuring PostgreSQL"

  local confdir pgconf pghba
  confdir="$(postgres_conf_dir)"
  [[ -n "$confdir" && -d "$confdir" ]] || { echo "Could not find /etc/postgresql/<ver>/main"; exit 1; }

  pgconf="${confdir}/postgresql.conf"
  pghba="${confdir}/pg_hba.conf"

  [[ -n "$PG_BLOG_PASS" ]] || PG_BLOG_PASS="$(rand_pass)"
  [[ -n "$PG_OS_PASS"   ]] || PG_OS_PASS="$(rand_pass)"

  # Enable remote listening if requested:
  # Ubuntu docs: listen_addresses='*' to accept TCP connections on all interfaces. [1](https://documentation.ubuntu.com/server/how-to/databases/install-postgresql/)[2](https://databasefaqs.com/postgresql-listen_addresses/)
  if [[ "$PG_ALLOW_REMOTE" -eq 1 ]]; then
    sed -i "s/^[#]*\s*listen_addresses\s*=.*$/listen_addresses = '*'/" "$pgconf"
  else
    sed -i "s/^[#]*\s*listen_addresses\s*=.*$/listen_addresses = 'localhost'/" "$pgconf"
  fi

  # Ensure strong password hashing for roles
  if grep -qE "^[#]*\s*password_encryption" "$pgconf"; then
    sed -i "s/^[#]*\s*password_encryption\s*=.*$/password_encryption = scram-sha-256/" "$pgconf"
  else
    echo "password_encryption = scram-sha-256" >> "$pgconf"
  fi

  # Ensure SSL enabled (Windows clients will typically use sslmode=require)
  # We point to the distro-provided snakeoil cert (created by ssl-cert package).
  if grep -qE "^[#]*\s*ssl\s*=" "$pgconf"; then
    sed -i "s/^[#]*\s*ssl\s*=.*$/ssl = on/" "$pgconf"
  else
    echo "ssl = on" >> "$pgconf"
  fi

  # Only set these if not already present (don’t fight custom certs)
  grep -qE "^\s*ssl_cert_file\s*=" "$pgconf" || echo "ssl_cert_file = '/etc/ssl/certs/ssl-cert-snakeoil.pem'" >> "$pgconf"
  grep -qE "^\s*ssl_key_file\s*="  "$pgconf" || echo "ssl_key_file  = '/etc/ssl/private/ssl-cert-snakeoil.key'" >> "$pgconf"

  # pg_hba rules:
  # Postgres reads pg_hba.conf on start and on reload/SIGHUP. [3](https://www.postgresql.org/docs/current/auth-pg-hba-conf.html)
  # Always allow local TCP with scram:
  grep -qE '^\s*host\s+all\s+all\s+127\.0\.0\.1/32\s+scram-sha-256' "$pghba" || \
    echo "host all all 127.0.0.1/32 scram-sha-256" >> "$pghba"
  grep -qE '^\s*host\s+all\s+all\s+::1/128\s+scram-sha-256' "$pghba" || \
    echo "host all all ::1/128 scram-sha-256" >> "$pghba"

  # Allow Windows IP (SSL required) if configured
  if [[ "$PG_ALLOW_REMOTE" -eq 1 && "$WINDOWS_IP_CIDR" != "YOUR_PUBLIC_IP/32" && -n "$WINDOWS_IP_CIDR" ]]; then
    if ! grep -qE "^\s*hostssl\s+all\s+all\s+${WINDOWS_IP_CIDR//\//\\/}\s+scram-sha-256" "$pghba"; then
      echo "hostssl all all ${WINDOWS_IP_CIDR} scram-sha-256" >> "$pghba"
    fi
  else
    warn "Skipping pg_hba Windows rule because WINDOWS_IP_CIDR is not set."
  fi

  systemctl restart postgresql

  log "Creating DBs/users if missing"
  sudo -u postgres psql -v ON_ERROR_STOP=1 <<EOF
DO \$\$
BEGIN
  IF NOT EXISTS (SELECT 1 FROM pg_roles WHERE rolname = '${PG_BLOG_USER}') THEN
    CREATE ROLE ${PG_BLOG_USER} LOGIN PASSWORD '${PG_BLOG_PASS}';
  END IF;
  IF NOT EXISTS (SELECT 1 FROM pg_database WHERE datname = '${PG_BLOG_DB}') THEN
    CREATE DATABASE ${PG_BLOG_DB} OWNER ${PG_BLOG_USER};
  END IF;

  IF NOT EXISTS (SELECT 1 FROM pg_roles WHERE rolname = '${PG_OS_USER}') THEN
    CREATE ROLE ${PG_OS_USER} LOGIN PASSWORD '${PG_OS_PASS}';
  END IF;
  IF NOT EXISTS (SELECT 1 FROM pg_database WHERE datname = '${PG_OS_DB}') THEN
    CREATE DATABASE ${PG_OS_DB} OWNER ${PG_OS_USER};
  END IF;
END
\$\$;
EOF

  log "Saving credentials to /root/.secrets/postgres-credentials.txt"
  mkdir -p /root/.secrets
  chmod 0700 /root/.secrets
  cat >/root/.secrets/postgres-credentials.txt <<EOF
BLOG DATABASE:
  DB=${PG_BLOG_DB}
  USER=${PG_BLOG_USER}
  PASS=${PG_BLOG_PASS}
  LOCAL_URL=postgresql://${PG_BLOG_USER}:${PG_BLOG_PASS}@localhost:5432/${PG_BLOG_DB}
  REMOTE_URL=postgresql://${PG_BLOG_USER}:${PG_BLOG_PASS}@${BLOG_DOMAIN}:5432/${PG_BLOG_DB}?sslmode=require

OS DATABASE:
  DB=${PG_OS_DB}
  USER=${PG_OS_USER}
  PASS=${PG_OS_PASS}
  LOCAL_URL=postgresql://${PG_OS_USER}:${PG_OS_PASS}@localhost:5432/${PG_OS_DB}
  REMOTE_URL=postgresql://${PG_OS_USER}:${PG_OS_PASS}@${BLOG_DOMAIN}:5432/${PG_OS_DB}?sslmode=require

Windows allowed CIDR: ${WINDOWS_IP_CIDR}
EOF
  chmod 0600 /root/.secrets/postgres-credentials.txt
}

###############
# ISO checksum tool
###############
install_iso_tool() {
  log "Installing publish_isos tool"
  cat >/usr/local/bin/publish_isos <<'EOF'
#!/usr/bin/env bash
set -euo pipefail
ISO_DIR="${1:-/srv/os/isos}"
cd "$ISO_DIR"
shopt -s nullglob
isos=( *.iso )
if [[ ${#isos[@]} -eq 0 ]]; then
  echo "No .iso files found in $ISO_DIR"
  exit 0
fi
sha256sum "${isos[@]}" > SHA256SUMS
echo "Updated: $ISO_DIR/SHA256SUMS"
EOF
  chmod 0755 /usr/local/bin/publish_isos
}

###############
# Nginx
###############
nginx_snippets() {
  mkdir -p /etc/nginx/snippets

  cat >/etc/nginx/snippets/security_headers.conf <<'EOF'
add_header X-Content-Type-Options "nosniff" always;
add_header X-Frame-Options "SAMEORIGIN" always;
add_header Referrer-Policy "strict-origin-when-cross-origin" always;
add_header X-XSS-Protection "0" always;
EOF

  cat >/etc/nginx/snippets/gzip.conf <<'EOF'
gzip on;
gzip_comp_level 6;
gzip_min_length 1024;
gzip_types text/plain text/css application/json application/javascript text/xml application/xml application/xml+rss text/javascript image/svg+xml;
EOF
}

configure_nginx_sites() {
  log "Configuring nginx sites"
  rm -f /etc/nginx/sites-enabled/default || true

  # Blog vhost
  cat >/etc/nginx/sites-available/blog.conf <<EOF
server {
  listen 80;
  server_name ${BLOG_DOMAIN};

  include /etc/nginx/snippets/security_headers.conf;
  include /etc/nginx/snippets/gzip.conf;

  client_max_body_size ${BLOG_MAX_UPLOAD};

  location /uploads/ {
    alias ${BLOG_UPLOAD_DIR}/;
    access_log off;
    expires 7d;
    add_header Cache-Control "public, max-age=604800";
    try_files \$uri =404;
  }
EOF

  if [[ "$BLOG_PROXY_ENABLED" -eq 1 ]]; then
    cat >>/etc/nginx/sites-available/blog.conf <<EOF

  location / {
    proxy_pass http://${BLOG_UPSTREAM_HOST}:${BLOG_UPSTREAM_PORT};
    proxy_http_version 1.1;
    proxy_set_header Host \$host;
    proxy_set_header X-Real-IP \$remote_addr;
    proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto \$scheme;
  }
}
EOF
  else
    cat >>/etc/nginx/sites-available/blog.conf <<EOF

  root ${BLOG_STATIC_ROOT};
  index index.html;

  location / {
    try_files \$uri \$uri/ =404;
  }
}
EOF
  fi

  # OS ISO vhost
  cat >/etc/nginx/sites-available/os.conf <<EOF
server {
  listen 80;
  server_name ${OS_DOMAIN};

  include /etc/nginx/snippets/security_headers.conf;

  root ${OS_ISO_DIR};
  autoindex on;
  autoindex_exact_size off;
  autoindex_localtime on;

  sendfile on;
  tcp_nopush on;

  location / {
    try_files \$uri \$uri/ =404;
  }
}
EOF

  # Optional CDN vhost
  if [[ -n "${CDN_DOMAIN}" ]]; then
    cat >/etc/nginx/sites-available/cdn.conf <<EOF
server {
  listen 80;
  server_name ${CDN_DOMAIN};

  include /etc/nginx/snippets/security_headers.conf;
  include /etc/nginx/snippets/gzip.conf;

  root ${BLOG_UPLOAD_DIR};

  location / {
    access_log off;
    expires 30d;
    add_header Cache-Control "public, max-age=2592000, immutable";
    try_files \$uri =404;
  }
}
EOF
    ln -sf /etc/nginx/sites-available/cdn.conf /etc/nginx/sites-enabled/cdn.conf
  fi

  ln -sf /etc/nginx/sites-available/blog.conf /etc/nginx/sites-enabled/blog.conf
  ln -sf /etc/nginx/sites-available/os.conf /etc/nginx/sites-enabled/os.conf

  nginx -t
  systemctl enable --now nginx
  systemctl reload nginx
}

###############
# Backups
###############
setup_pg_backups() {
  log "Setting up daily Postgres backups (7-day retention)"
  mkdir -p "$BACKUP_DIR"
  chmod 0750 "$BACKUP_DIR"

  cat >/etc/cron.daily/pg-backup <<EOF
#!/usr/bin/env bash
set -euo pipefail
BACKUP_DIR="${BACKUP_DIR}"
TS="\$(date +%F-%H%M%S)"
mkdir -p "\$BACKUP_DIR"
chmod 0750 "\$BACKUP_DIR"

sudo -u postgres pg_dump "${PG_BLOG_DB}" | gzip > "\$BACKUP_DIR/${PG_BLOG_DB}-\$TS.sql.gz"
sudo -u postgres pg_dump "${PG_OS_DB}"   | gzip > "\$BACKUP_DIR/${PG_OS_DB}-\$TS.sql.gz"

find "\$BACKUP_DIR" -type f -name "*.sql.gz" -mtime +7 -delete
EOF
  chmod 0755 /etc/cron.daily/pg-backup
}

###############
# TLS
###############
obtain_tls() {
  if [[ "$ENABLE_TLS" -ne 1 ]]; then
    warn "TLS disabled (ENABLE_TLS=0). Sites will be HTTP only."
    warn "After DNS is live and port 80 reachable, set ENABLE_TLS=1 and rerun."
    return 0
  fi

  log "Issuing Let's Encrypt certificates via certbot --nginx"
  # Certbot nginx method expects HTTP site reachable on port 80. [7](https://certbot.eff.org/instructions?ws=nginx&os=ubuntufocal)[8](https://www.digitalocean.com/community/tutorials/how-to-secure-nginx-with-let-s-encrypt-on-ubuntu-20-04)
  args=(-m "$LE_EMAIL" --agree-tos --no-eff-email --nginx --redirect -d "$BLOG_DOMAIN" -d "$OS_DOMAIN")
  if [[ -n "$CDN_DOMAIN" ]]; then
    args+=(-d "$CDN_DOMAIN")
  fi
  certbot "${args[@]}" || warn "Certbot failed. Verify DNS and firewall reachability."
}

###############
# Summary
###############
print_summary() {
  log "✅ Setup complete"

  echo "Web:"
  echo "  BLOG: http(s)://${BLOG_DOMAIN}/"
  echo "    uploads dir: ${BLOG_UPLOAD_DIR} served as /uploads/"
  echo "  OS:   http(s)://${OS_DOMAIN}/ (ISO downloads, autoindex)"
  [[ -n "$CDN_DOMAIN" ]] && echo "  CDN:  http(s)://${CDN_DOMAIN}/ (uploads root)"

  echo
  echo "Postgres:"
  echo "  Credentials: /root/.secrets/postgres-credentials.txt"
  echo "  Remote from Windows allowed CIDR: ${WINDOWS_IP_CIDR}"
  echo "  Test locally: psql \"postgresql://${PG_BLOG_USER}:${PG_BLOG_PASS}@localhost:5432/${PG_BLOG_DB}\""
  echo "  Test remote (Windows): use sslmode=require"

  echo
  echo "Uploads:"
  echo "  ISOs:  ${OS_ISO_DIR}  -> run: publish_isos ${OS_ISO_DIR}"
  echo "  Images:${BLOG_UPLOAD_DIR}"
}

main() {
  require_root
  install_packages
  ensure_user "$BLOG_USER"
  ensure_user "$OS_USER"
  create_dirs
  configure_ufw
  configure_fail2ban
  configure_unattended
  nginx_snippets
  configure_postgres
  install_iso_tool
  configure_nginx_sites
  setup_pg_backups
  obtain_tls
  print_summary
}

main "$@"

