#!/usr/bin/env bash
set -euo pipefail

#################################
# CONFIG — EDIT THESE
#################################

OS_DOMAIN="os.example.com"
CDN_DOMAIN="cdn.example.com"   # blog images
LE_EMAIL="you@example.com"

ENABLE_TLS=0   # set to 1 after DNS is live

OS_USER="osapp"
BLOG_USER="blogapp"

BASE_DIR="/srv/data"
OS_ISO_DIR="$BASE_DIR/os/isos"
BLOG_UPLOAD_DIR="$BASE_DIR/blog/uploads"

#################################
# FUNCTIONS
#################################

log() { echo -e "\n\033[1;32m==>\033[0m $*"; }

require_root() {
  [[ $EUID -eq 0 ]] || { echo "Run as root"; exit 1; }
}

create_user() {
  id "$1" &>/dev/null || useradd -m -s /usr/sbin/nologin "$1"
}

#################################
# MAIN
#################################

require_root

log "Installing base packages"
apt update -y
apt install -y nginx ufw fail2ban certbot python3-certbot-nginx \
               postgresql-client curl unzip

log "Firewall"
ufw allow OpenSSH
ufw allow "Nginx Full"
ufw --force enable

log "Users"
create_user "$OS_USER"
create_user "$BLOG_USER"

log "Directories"
mkdir -p "$OS_ISO_DIR" "$BLOG_UPLOAD_DIR"
chown -R "$OS_USER:$OS_USER" "$BASE_DIR/os"
chown -R "$BLOG_USER:$BLOG_USER" "$BASE_DIR/blog"
chmod -R 750 "$BASE_DIR"

#################################
# ISO CHECKSUM TOOL
#################################

log "Installing ISO checksum helper"

cat >/usr/local/bin/publish_isos <<'EOF'
#!/usr/bin/env bash
set -e
cd /srv/data/os/isos
sha256sum *.iso > SHA256SUMS
echo "SHA256SUMS updated"
EOF

chmod +x /usr/local/bin/publish_isos

#################################
# NGINX CONFIG
#################################

log "Nginx static sites"

cat >/etc/nginx/sites-available/os.conf <<EOF
server {
  listen 80;
  server_name $OS_DOMAIN;

  root $OS_ISO_DIR;
  autoindex on;

  add_header Access-Control-Allow-Origin "*" always;
}
EOF

cat >/etc/nginx/sites-available/cdn.conf <<EOF
server {
  listen 80;
  server_name $CDN_DOMAIN;

  root $BLOG_UPLOAD_DIR;

  location / {
    access_log off;
    expires 30d;
    add_header Cache-Control "public, immutable";
    add_header Access-Control-Allow-Origin "*" always;
  }
}
EOF

ln -sf /etc/nginx/sites-available/os.conf /etc/nginx/sites-enabled/
ln -sf /etc/nginx/sites-available/cdn.conf /etc/nginx/sites-enabled/
rm -f /etc/nginx/sites-enabled/default

nginx -t && systemctl reload nginx

#################################
# TLS (OPTIONAL)
#################################

if [[ "$ENABLE_TLS" == "1" ]]; then
  certbot --nginx -m "$LE_EMAIL" --agree-tos \
    -d "$OS_DOMAIN" -d "$CDN_DOMAIN" --redirect
fi

log "DONE ✅"

echo "
Next steps:
- Point DNS:
    $OS_DOMAIN  -> VPS IP
    $CDN_DOMAIN -> VPS IP

- Upload ISOs:
    scp *.iso $OS_USER@server:/srv/data/os/isos/
    sudo publish_isos

- Upload blog images:
    scp image.webp $BLOG_USER@server:/srv/data/blog/uploads/

Public URLs:
- https://$OS_DOMAIN/
- https://$CDN_DOMAIN/<image>
"