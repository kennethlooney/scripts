#!/usr/bin/env bash
set -euo pipefail

# ===========================
# ISO file server bootstrapper
# Ubuntu + Nginx + /srv/isos
# ===========================

# ---- Config (edit these) ----
ISO_USER="${ISO_USER:-fileserver}"          # user you SCP as
SERVER_NAME="${SERVER_NAME:-_}"             # domain like megos.kennethlooney.com or "_" for default
WEB_ROOT="${WEB_ROOT:-/srv/isos}"
SITE_NAME="${SITE_NAME:-downloads}"         # nginx site filename
ENABLE_UFW="${ENABLE_UFW:-yes}"             # yes/no
AUTO_INDEX="${AUTO_INDEX:-on}"              # on/off

# ---- Helpers ----
log() { echo -e "\n\033[1;32m==>\033[0m $*"; }
warn() { echo -e "\n\033[1;33m[!]\033[0m $*"; }

if [[ $EUID -ne 0 ]]; then
  warn "Please run as root (or with sudo): sudo $0"
  exit 1
fi

log "Updating system packages..."
apt update -y
apt upgrade -y

log "Installing Nginx..."
apt install -y nginx

log "Ensuring Nginx is enabled and running..."
systemctl enable --now nginx

if [[ "${ENABLE_UFW}" == "yes" ]]; then
  log "Configuring UFW firewall (OpenSSH/HTTP/HTTPS)..."
  apt install -y ufw
  ufw allow OpenSSH
  ufw allow 80/tcp
  ufw allow 443/tcp
  ufw --force enable
  ufw status
else
  warn "Skipping UFW setup (ENABLE_UFW=no)."
fi

# Create the upload user if it doesn't exist
if id "${ISO_USER}" &>/dev/null; then
  log "User '${ISO_USER}' already exists."
else
  log "Creating user '${ISO_USER}'..."
  adduser --disabled-password --gecos "" "${ISO_USER}"
  usermod -aG sudo "${ISO_USER}"
  log "User '${ISO_USER}' created (no password set). You may want to set one: passwd ${ISO_USER}"
fi

log "Creating web root at ${WEB_ROOT}..."
mkdir -p "${WEB_ROOT}"

log "Setting ownership to ${ISO_USER}:www-data..."
chown -R "${ISO_USER}":www-data "${WEB_ROOT}"

log "Setting permissions: directories 775, files 664..."
find "${WEB_ROOT}" -type d -exec chmod 775 {} \;
find "${WEB_ROOT}" -type f -exec chmod 664 {} \;

log "Setting setgid bit on ${WEB_ROOT} so new uploads inherit group www-data..."
chmod g+s "${WEB_ROOT}"

# Nginx site config
NGINX_AVAILABLE="/etc/nginx/sites-available/${SITE_NAME}"
NGINX_ENABLED="/etc/nginx/sites-enabled/${SITE_NAME}"

log "Writing Nginx site config to ${NGINX_AVAILABLE}..."
cat > "${NGINX_AVAILABLE}" <<EOF
server {
    listen 80;
    server_name ${SERVER_NAME};

    root ${WEB_ROOT};
    autoindex ${AUTO_INDEX};
    autoindex_exact_size off;
    autoindex_localtime on;

    # Efficient large file downloads
    sendfile on;
    tcp_nopush on;
    tcp_nodelay on;

    access_log /var/log/nginx/${SITE_NAME}.access.log;
    error_log  /var/log/nginx/${SITE_NAME}.error.log;
}
EOF

log "Enabling Nginx site..."
ln -sf "${NGINX_AVAILABLE}" "${NGINX_ENABLED}"

# Optionally remove default site if present
if [[ -e /etc/nginx/sites-enabled/default ]]; then
  log "Removing default Nginx site..."
  rm -f /etc/nginx/sites-enabled/default
fi

log "Testing Nginx configuration..."
nginx -t

log "Reloading Nginx..."
systemctl reload nginx

log "Done!"
echo "------------------------------------------------------------"
echo "Web root:     ${WEB_ROOT}"
echo "Upload user:  ${ISO_USER}"
echo "Server name:  ${SERVER_NAME}"
echo ""
echo "Next:"
echo "  1) Upload files:"
echo "     scp your.iso your.iso.sha256 ${ISO_USER}@<server>:/srv/isos/"
echo ""
echo "  2) Verify perms:"
echo "     ls -lh ${WEB_ROOT}"
echo ""
echo "Optional HTTPS (recommended):"
echo "  sudo apt install -y certbot python3-certbot-nginx"
echo "  sudo certbot --nginx -d <your-domain>"
echo "------------------------------------------------------------"