#!/usr/bin/env bash
set -euo pipefail

# ===========================
# ISO file server bootstrapper
# Ubuntu + Nginx + /srv/isos
# ===========================

# ---- Config defaults (can be overridden via env vars) ----
ISO_USER="${ISO_USER:-fileserver}"          # user you SCP as
SERVER_NAME="${SERVER_NAME:-_}"             # domain like downloads.example.com, IP, or "_"
WEB_ROOT="${WEB_ROOT:-/srv/isos}"
SITE_NAME="${SITE_NAME:-downloads}"         # nginx site filename
ENABLE_UFW="${ENABLE_UFW:-yes}"             # yes/no
AUTO_INDEX="${AUTO_INDEX:-on}"              # on/off
RUN_UPGRADE="${RUN_UPGRADE:-yes}"           # yes/no
NON_INTERACTIVE="${NON_INTERACTIVE:-no}"    # yes/no or --non-interactive flag

# ---- Helpers ----
log() { echo -e "\n\033[1;32m==>\033[0m $*"; }
warn() { echo -e "\n\033[1;33m[!]\033[0m $*"; }
die() { echo -e "\n\033[1;31m[x]\033[0m $*"; exit 1; }

usage() {
  cat <<'EOF'
Usage:
  sudo ./fileserver [--non-interactive]

Optional env vars:
  ISO_USER, SERVER_NAME, WEB_ROOT, SITE_NAME, ENABLE_UFW, AUTO_INDEX, RUN_UPGRADE, NON_INTERACTIVE

Examples:
  sudo ISO_USER=release SERVER_NAME=downloads.example.com ./fileserver
  sudo ./fileserver --non-interactive
EOF
}

is_yes() {
  [[ "${1,,}" == "yes" || "${1,,}" == "y" ]]
}

prompt_value() {
  local var_name="$1"
  local prompt_text="$2"
  local default_value="$3"
  local value

  while true; do
    read -r -p "${prompt_text} [${default_value}]: " value
    value="${value:-$default_value}"
    if [[ -n "$value" ]]; then
      printf -v "$var_name" "%s" "$value"
      return
    fi
    warn "Value cannot be empty."
  done
}

prompt_yes_no() {
  local var_name="$1"
  local prompt_text="$2"
  local default_value="$3"
  local value

  while true; do
    read -r -p "${prompt_text} (yes/no) [${default_value}]: " value
    value="${value:-$default_value}"
    case "${value,,}" in
      y|yes) printf -v "$var_name" "yes"; return ;;
      n|no)  printf -v "$var_name" "no"; return ;;
      *) warn "Please answer yes or no." ;;
    esac
  done
}

validate_config() {
  [[ "$ISO_USER" =~ ^[a-z_][a-z0-9_-]*$ ]] || die "ISO_USER must be a valid Linux username."
  [[ "$SITE_NAME" =~ ^[a-zA-Z0-9._-]+$ ]] || die "SITE_NAME may only contain letters, numbers, dot, underscore, or hyphen."
  [[ "$WEB_ROOT" == /* ]] || die "WEB_ROOT must be an absolute path."
  [[ "$ENABLE_UFW" == "yes" || "$ENABLE_UFW" == "no" ]] || die "ENABLE_UFW must be yes or no."
  [[ "$RUN_UPGRADE" == "yes" || "$RUN_UPGRADE" == "no" ]] || die "RUN_UPGRADE must be yes or no."
  [[ "$AUTO_INDEX" == "on" || "$AUTO_INDEX" == "off" ]] || die "AUTO_INDEX must be on or off."
}

for arg in "$@"; do
  case "$arg" in
    --non-interactive) NON_INTERACTIVE="yes" ;;
    -h|--help) usage; exit 0 ;;
    *) die "Unknown option: $arg" ;;
  esac
done

if [[ $EUID -ne 0 ]]; then
  warn "Please run as root (or with sudo): sudo $0"
  exit 1
fi

if ! command -v apt >/dev/null 2>&1; then
  die "This script currently supports Ubuntu/Debian systems with apt."
fi

if ! is_yes "$NON_INTERACTIVE"; then
  log "Interactive setup: provide values for this project."
  prompt_value ISO_USER "Upload username" "$ISO_USER"
  prompt_value SERVER_NAME "Server name (domain/IP or _)" "$SERVER_NAME"
  prompt_value WEB_ROOT "Web root path" "$WEB_ROOT"
  prompt_value SITE_NAME "Nginx site name" "$SITE_NAME"
  prompt_yes_no ENABLE_UFW "Enable UFW firewall rules for SSH/HTTP/HTTPS" "$ENABLE_UFW"
  prompt_yes_no RUN_UPGRADE "Run full package upgrade before install" "$RUN_UPGRADE"

  if [[ "$AUTO_INDEX" != "on" && "$AUTO_INDEX" != "off" ]]; then
    AUTO_INDEX="on"
  fi
  while true; do
    read -r -p "Enable directory listing (autoindex) (on/off) [${AUTO_INDEX}]: " value
    value="${value:-$AUTO_INDEX}"
    case "${value,,}" in
      on|off) AUTO_INDEX="${value,,}"; break ;;
      *) warn "Please answer on or off." ;;
    esac
  done
fi

validate_config

log "Configuration summary:"
echo "  ISO_USER:     ${ISO_USER}"
echo "  SERVER_NAME:  ${SERVER_NAME}"
echo "  WEB_ROOT:     ${WEB_ROOT}"
echo "  SITE_NAME:    ${SITE_NAME}"
echo "  ENABLE_UFW:   ${ENABLE_UFW}"
echo "  RUN_UPGRADE:  ${RUN_UPGRADE}"
echo "  AUTO_INDEX:   ${AUTO_INDEX}"

if ! is_yes "$NON_INTERACTIVE"; then
  read -r -p "Continue with setup? (yes/no) [yes]: " proceed
  proceed="${proceed:-yes}"
  is_yes "$proceed" || die "Setup canceled."
fi

log "Updating system packages..."
apt update -y
if [[ "${RUN_UPGRADE}" == "yes" ]]; then
  apt upgrade -y
else
  warn "Skipping full package upgrade (RUN_UPGRADE=no)."
fi

log "Installing Nginx..."
apt install -y nginx

log "Ensuring Nginx is enabled and running..."
systemctl enable --now nginx

if [[ "${ENABLE_UFW}" == "yes" ]]; then
  log "Configuring UFW firewall (OpenSSH/HTTP/HTTPS)..."
  apt install -y ufw
  ufw allow OpenSSH
  ufw allow 80/tcp
  ufw allow 443/tcp
  ufw --force enable
  ufw status
else
  warn "Skipping UFW setup (ENABLE_UFW=no)."
fi

# Create the upload user if it doesn't exist
if id "${ISO_USER}" &>/dev/null; then
  log "User '${ISO_USER}' already exists."
else
  log "Creating user '${ISO_USER}'..."
  adduser --disabled-password --gecos "" "${ISO_USER}"
  usermod -aG sudo "${ISO_USER}"
  log "User '${ISO_USER}' created (no password set). You may want to set one: passwd ${ISO_USER}"
fi

log "Creating web root at ${WEB_ROOT}..."
mkdir -p "${WEB_ROOT}"

log "Setting ownership to ${ISO_USER}:www-data..."
chown -R "${ISO_USER}":www-data "${WEB_ROOT}"

log "Setting permissions: directories 775, files 664..."
find "${WEB_ROOT}" -type d -exec chmod 775 {} \;
find "${WEB_ROOT}" -type f -exec chmod 664 {} \;

log "Setting setgid bit on ${WEB_ROOT} so new uploads inherit group www-data..."
chmod g+s "${WEB_ROOT}"

# Nginx site config
NGINX_AVAILABLE="/etc/nginx/sites-available/${SITE_NAME}"
NGINX_ENABLED="/etc/nginx/sites-enabled/${SITE_NAME}"

log "Writing Nginx site config to ${NGINX_AVAILABLE}..."
cat > "${NGINX_AVAILABLE}" <<EOF
server {
    listen 80;
    server_name ${SERVER_NAME};

    root ${WEB_ROOT};
    autoindex ${AUTO_INDEX};
    autoindex_exact_size off;
    autoindex_localtime on;

    # Efficient large file downloads
    sendfile on;
    tcp_nopush on;
    tcp_nodelay on;

    access_log /var/log/nginx/${SITE_NAME}.access.log;
    error_log  /var/log/nginx/${SITE_NAME}.error.log;
}
EOF

log "Enabling Nginx site..."
ln -sf "${NGINX_AVAILABLE}" "${NGINX_ENABLED}"

# Optionally remove default site if present
if [[ -e /etc/nginx/sites-enabled/default ]]; then
  log "Removing default Nginx site..."
  rm -f /etc/nginx/sites-enabled/default
fi

log "Testing Nginx configuration..."
nginx -t

log "Reloading Nginx..."
systemctl reload nginx

log "Done!"
echo "------------------------------------------------------------"
echo "Web root:     ${WEB_ROOT}"
echo "Upload user:  ${ISO_USER}"
echo "Server name:  ${SERVER_NAME}"
echo ""
echo "Next:"
echo "  1) Upload files:"
echo "     scp your.iso your.iso.sha256 ${ISO_USER}@<server>:${WEB_ROOT}/"
echo ""
echo "  2) Verify perms:"
echo "     ls -lh ${WEB_ROOT}"
echo ""
echo "Optional HTTPS (recommended):"
echo "  sudo apt install -y certbot python3-certbot-nginx"
echo "  sudo certbot --nginx -d <your-domain>"
echo "------------------------------------------------------------"
